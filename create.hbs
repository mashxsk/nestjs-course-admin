<!DOCTYPE html>
<html>
<head>
    <title>Додавання курсу</title>
    <meta charset="utf-8" />
    <style>
        body { font-family: sans-serif; max-width: 400px; margin: 20px auto; }
        .field { width: 100%; padding: 6px; margin-bottom: 15px; box-sizing: border-box;}
        label { font-weight: bold; }
        .btn { padding: 8px 15px; cursor: pointer; background-color: #4CAF50; color: white; border: none; border-radius: 4px; }
    </style>
</head>
<body>
    <h2>Додавання курсу</h2>
    <form action="/courses/create" method="POST">
        <label>Назва курсу:</label><br>
        <input name="title" class="field" required placeholder="Наприклад: React для початківців" />
        
        <label>Викладач:</label><br>
        <input name="instructor" class="field" required placeholder="Прізвище І.Б." />
        
        <label>Тривалість (год):</label><br>
        <input name="duration" type="number" class="field" required placeholder="40" min="1" />
        
        <input type="submit" value="Зберегти" class="btn" />
    </form>
    <br>
    <a href="/">До списку курсів</a>
</body>
</html>