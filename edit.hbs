<!DOCTYPE html>
<html>
<head>
    <title>Редагування курсу</title>
    <meta charset="utf-8" />
    <style>
        body { font-family: sans-serif; max-width: 400px; margin: 20px auto; }
        .field { width: 100%; padding: 6px; margin-bottom: 15px; box-sizing: border-box;}
        label { font-weight: bold; }
        .btn { padding: 8px 15px; cursor: pointer; background-color: #4CAF50; color: white; border: none; border-radius: 4px; }
    </style>
</head>
<body>
    <h2>Редагування курсу</h2>
    <form action="/courses/edit" method="POST">
        <input type="hidden" name="id" value="{{course.id}}" />
        
        <label>Назва курсу:</label><br>
        <input name="title" value="{{course.title}}" class="field" required />
        
        <label>Викладач:</label><br>
        <input name="instructor" value="{{course.instructor}}" class="field" required />
        
        <label>Тривалість (год):</label><br>
        <input name="duration" type="number" value="{{course.duration}}" class="field" required min="1" />
        
        <input type="submit" value="Зберегти зміни" class="btn" />
    </form>
    <br>
    <a href="/">До списку курсів</a>
</body>
</html>