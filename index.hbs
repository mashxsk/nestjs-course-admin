<!DOCTYPE html>
<html>
<head>
    <title>Освітня платформа - Курси</title>
    <meta charset="utf-8" />
    <style>
        body { font-family: sans-serif; max-width: 800px; margin: 20px auto; }
        td, th { padding: 8px; border-bottom: 1px solid #ddd; text-align: left; }
        th { background-color: #f2f2f2; }
        table { width: 100%; border-collapse: collapse; }
        .btn { padding: 5px 10px; margin: 2px; cursor: pointer; text-decoration: none; border: 1px solid #ccc; background-color: #e7e7e7; color: black; border-radius: 4px; font-size: 14px;}
        .btn:hover { background-color: #d7d7d7; }
    </style>
</head>
<body>
    <h1>Адміністрування курсів</h1>
    <p><a href="/courses/create" class="btn" style="background-color: #4CAF50; color: white; border:none;">Додати курс</a></p>
    
    <table>
        <tr>
            <th>Назва курсу</th>
            <th>Викладач</th>
            <th>Години</th>
            <th>Дії</th>
        </tr>
        {{#each courses}}
            <tr>
                <td>{{this.title}}</td>
                <td>{{this.instructor}}</td>
                <td>{{this.duration}}</td>
                <td>
                    <a href="/courses/edit/{{this.id}}" class="btn">Редагувати</a>
                    <form action="/courses/delete/{{this.id}}" method="POST" style="display:inline;">
                        <input type="submit" value="Видалити" class="btn" style="color: red;" />
                    </form>
                </td>
            </tr>
        {{/each}}
    </table>
</body>
</html>